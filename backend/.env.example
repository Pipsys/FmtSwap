# Security — CHANGE THESE IN PRODUCTION
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF
CSRF_SECRET=change-this-csrf-secret-too

# PostgreSQL
DATABASE_URL=postgresql://pdf_user:pdf_password@localhost:5432/pdf2docx

# CORS
FRONTEND_URL=http://localhost:5173

# File limits
MAX_FILE_SIZE_MB=50
HOSTING_MAX_FILE_SIZE_MB=100
HOSTING_MAX_FILE_SIZE_AUTH_MB=300
GUEST_FILE_TTL_MINUTES=15

# PDF detect + OCR pipeline
PDF_DETECT_SAMPLE_PAGES=5
PDF_TEXT_MIN_CHARS_PER_PAGE=50
PDF_TEXT_MIN_PAGES=1
ENABLE_SCANNED_OCR=true
OCR_LANG=rus+eng
TESSDATA_PREFIX=


# Storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
HOSTING_DIR=hosting
