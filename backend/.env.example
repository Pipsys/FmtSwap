# Security — CHANGE THESE IN PRODUCTION
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF
CSRF_SECRET=change-this-csrf-secret-too

# PostgreSQL
DATABASE_URL=postgresql://pdf_user:pdf_password@localhost:5432/pdf2docx

# CORS
FRONTEND_URL=http://localhost:5173

# File limits
MAX_FILE_SIZE_MB=50

# Storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
